# ── Moon PromptCard 后端配置 ───────────────────────────────────────────
# 复制本文件为 .env 后填写。.env 已被 .gitignore 忽略，绝不提交、绝不进前端。

# 服务端口
PORT=8787

# 允许的跨域来源。开发时填扩展的 chrome-extension://<你的扩展ID>，
# 多个用逗号分隔。留空 = 开发模式放开所有来源（仅本地用）。
CORS_ORIGINS=

# ── 文本 / 提示词 / 读图模型（OpenAI 兼容网关）─────────────────────────
# 用 AI充电站（aidraw365）这类 OpenAI 兼容网关：走 /v1/chat/completions。
# 例：LLM_BASE_URL=https://aidraw365.com/v1
# key 只存在这里，绝不进前端。
LLM_BASE_URL=https://aidraw365.com/v1
LLM_API_KEY=
# 纯文本分析用 LLM_TEXT_MODEL，带参考图分析用 LLM_VISION_MODEL。
# 网关只有一个 chat 模型时，两者都填同一个（如 qwen-vl-plus）即可。
LLM_TEXT_MODEL=qwen-vl-plus
LLM_VISION_MODEL=qwen-vl-plus

# ── 图片生成（同一网关，OpenAI 兼容）───────────────────────────────────
# 留空则自动复用上面的 LLM_BASE_URL / LLM_API_KEY。
# 文生图走 /v1/images/generations；图生图走 /v1/images/edits。
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_EDIT_MODEL=nanobanana-2

# ── 持久化（生产必填）───────────────────────────────────────────────────
# Postgres 连接串（Render/Railway 创建数据库后会提供 DATABASE_URL）。
# 留空 = 内存存储，重启清空，仅本地用。
DATABASE_URL=
# token 签名密钥，生产务必设为随机长字符串，否则重启后登录全部失效。
JWT_SECRET=

# ── 配额 ────────────────────────────────────────────────────────────────
# 新用户初始分析次数
FREE_QUOTA=20

# ── 支付占位 ────────────────────────────────────────────────────────────
# 购买按钮跳转的外部支付页（Stripe/Paddle/Lemon Squeezy 等）
CHECKOUT_URL=https://example.com/moon-promptcard/checkout

# ── 邮件发送（可选）──────────────────────────────────────────────────────
# 留空 = 开发模式：验证码不真正发邮件，而是打印到服务端控制台，
# 并在响应里返回 devCode 方便联调。生产请接真实 SMTP/邮件服务。
SMTP_URL=
MAIL_FROM=Moon PromptCard <no-reply@example.com>
